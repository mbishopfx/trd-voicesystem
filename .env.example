# Required for outbound calls
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
VAPI_INBOUND_ASSISTANT_ID=
VAPI_ASSISTANT_ID_FEMALE=
VAPI_ASSISTANT_ID_MALE=
VAPI_PROSPECTOR_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional overrides
VAPI_BASE_URL=https://api.vapi.ai
PORT=3000
DATABASE_URL=
WEBHOOK_SECRET=
BOOKING_URL=https://calendly.com/your-team/intro
BOOKING_URL_CALENDLY=
BOOKING_URL_GOOGLE_CALENDAR=
BOOKING_PROVIDER=calendly
CAMPAIGN_NAME=Warm Lead Outreach

# Rate limits
TWILIO_CPS=1
VAPI_CALL_CREATE_RPS=3
SYSTEM_CPS=1
MAX_CONCURRENT_DIALS=1

# Retries
MAX_ATTEMPTS=3
RETRY_BASE_SECONDS=30
RETRY_MAX_SECONDS=900

# Call guardrails
MAX_CALL_SECONDS=180
POST_CALL_DELAY_SECONDS=30
REQUIRE_OPT_IN=true
TRUST_ALL_IMPORTS=true
DEFAULT_TIMEZONE=America/New_York
CALL_WINDOW_START_HOUR=9
CALL_WINDOW_END_HOUR=18
ASSISTANT_WAITS_FOR_USER=false
VOICEMAIL_DETECTION_PROVIDER=vapi
VOICEMAIL_DETECTION_START_AT_SECONDS=2
VOICEMAIL_DETECTION_FREQUENCY_SECONDS=2.5
VOICEMAIL_DETECTION_MAX_RETRIES=6
VOICEMAIL_BEEP_MAX_AWAIT_SECONDS=30

# Scheduler
RUN_INGEST_ON_START=true
INGEST_INTERVAL_HOURS=24
DIALER_TICK_MS=250
RECONCILE_INTERVAL_SECONDS=60
RECONCILE_MIN_AGE_SECONDS=180
RETARGET_AUTO_EXPORT=true
WIN_SMS_ENABLED=true
WIN_SMS_TEMPLATE=Hi {{firstName}}, book your free AI Search Optimization strategy session here: {{bookingUrl}}
PROSPECTOR_WIN_SMS_TEMPLATE=Hi {{firstName}}, here is the live vision link: {{liveLink}}. If you want to move forward, book here: {{bookingUrl}}. A team member may reach out before the meeting.
SMS_CAMPAIGN_DEFAULT_TEMPLATE=hey [first_name], was just looking at [company_name]'s site and noticed something a little weird... u the owner?
SMS_CAMPAIGN_REPLY_TEMPLATE=[my_name] with truerankdigital.com. honestly nothing is actually broken, i just noticed you guys are basically invisible on google's new ai overviews for [city] and your competitors are eating up all the traffic. usually means your entity setup is off. u guys handling your seo in-house right now or do u have an agency?
SMS_CAMPAIGN_DEFAULT_MY_NAME=Jarvis

# Optional GoHighLevel sync
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_SYNC_ON_CALL_ATTEMPT=false

# Optional Calendly + Google Calendar webhook verification
CALENDLY_ACCESS_TOKEN=
CALENDLY_WEBHOOK_SIGNING_KEY=
GOOGLE_CALENDAR_WEBHOOK_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_PROSPECTOR_MODEL=gemini-3.0-flash
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-3-mini-beta
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
APOLLO_API_KEY=
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_TIMEOUT_MS=15000
PROSPECTOR_GHL_AUTO_SYNC=true
PROSPECTOR_AUTO_SCHEDULER_ENABLED=true
PROSPECTOR_AUTO_SCHEDULER_TIMEZONE=America/New_York
PROSPECTOR_AUTO_SCHEDULER_HOURS=9,14
PROSPECTOR_AUTO_SCHEDULER_TICK_SECONDS=30
PROSPECTOR_AUTO_SCHEDULER_RUN_WINDOW_MINUTES=5
PROSPECTOR_AUTO_SCHEDULER_ICP_POOL=med spa,roofing contractor,plumber,dental clinic,real estate broker,chiropractor,personal injury law firm,home remodeling contractor,landscaping company,HVAC contractor
PROSPECTOR_AUTO_SCHEDULER_NJ_CITIES=Newark,Jersey City,Paterson,Elizabeth,Edison,Woodbridge,Lakewood,Toms River,Trenton,Clifton,Camden,Hoboken

# Optional Vapi custom-tools runtime guard (used by /tools/vapi)
# If set, Vapi tool requests must include x-vapi-secret/authorization containing this value.
# WEBHOOK_SECRET=
